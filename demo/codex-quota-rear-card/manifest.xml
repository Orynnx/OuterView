<?xml version="1.0" encoding="utf-8"?>
<Widget version="2" frameRate="0" screenWidth="1080" scaleByDensity="false" useVariableUpdater="DateTime.Minute">
  <!-- Xiaomi rear display reference canvas: 480x304. -->
  <Var name="card_scale" type="number" expression="min((#view_width / 480),(#view_height / 304))"/>
  <Var name="card_offset_x" type="number" expression="((#view_width - (480 * #card_scale)) / 2)"/>
  <Var name="card_offset_y" type="number" expression="((#view_height - (304 * #card_scale)) / 2)"/>

  <!-- Quota values are clamped before drawing. No new provider fields are required. -->
  <Var name="fiveSafe" type="number" expression="ifelse(#five_hour_remaining{0,0,ifelse(#five_hour_remaining}100,100,#five_hour_remaining))"/>
  <Var name="weekSafe" type="number" expression="ifelse(#weekly_remaining{0,0,ifelse(#weekly_remaining}100,100,#weekly_remaining))"/>
  <Var name="isBound" type="number" expression="ifelse(strIsEmpty(@updated_at),0,1)"/>
  <Var name="hasFive" type="number" expression="ifelse(#isBound ** (#five_hour_remaining}-1),1,0)"/>
  <Var name="hasWeek" type="number" expression="ifelse(#isBound ** (#weekly_remaining}-1),1,0)"/>
  <!-- 0 none, 1 weekly-only, 2 five-hour-only, 3 both. -->
  <Var name="quotaState" type="number" expression="(#hasFive*2+#hasWeek)"/>

  <Var name="fiveLabel" type="string" expression="#fiveSafe+'%'"/>
  <Var name="weekLabel" type="string" expression="#weekSafe+'%'"/>
  <Var name="fiveColor" type="number" expression="ifelse(#fiveSafe{15,0xffef4146,ifelse(#fiveSafe{35,0xffc77a10,0xfff4f4ef))"/>
  <Var name="weekColor" type="number" expression="ifelse(#weekSafe{15,0xffef4146,ifelse(#weekSafe{35,0xffc77a10,0xfff4f4ef))"/>

  <Var name="singleSafe" type="number" expression="ifelse(#quotaState==1,#weekSafe,#fiveSafe)"/>
  <Var name="singleLabel" type="string" expression="ifelse(#quotaState==1,@weekLabel,@fiveLabel)"/>
  <Var name="singleTitle" type="string" expression="ifelse(#quotaState==1,'Weekly remaining','5-hour remaining')"/>
  <Var name="singleReset" type="string" expression="ifelse(#quotaState==1,@weekly_reset,@five_hour_reset)"/>
  <Var name="singleColor" type="number" expression="ifelse(#quotaState==1,#weekColor,#fiveColor)"/>

  <Var name="statusColor" type="number" expression="ifelse(eqs(@status,'OK'),0xff10a37f,ifelse(eqs(@status,'Not signed in'),0xff7c7c76,0xffc77a10))"/>
  <Var name="footerLabel" type="string" expression="ifelse(strIsEmpty(@updated_at),ifelse(eqs(@status,'Not signed in'),'Not connected','No update yet'),'Last update '+@updated_at)"/>
  <Var name="emptyTitle" type="string" expression="ifelse(eqs(@status,'OK'),'No quota window','Connect companion')"/>
  <Var name="emptyDetail" type="string" expression="ifelse(eqs(@status,'OK'),'No usage limits were returned','Open OuterView Quota to continue')"/>

  <Rectangle w="#view_width" h="#view_height" fillColor="#ff0d0d0c"/>

  <Group x="#card_offset_x" y="#card_offset_y" scaleX="#card_scale" scaleY="#card_scale">
    <!-- Camera-safe content starts at x=183. The host time overlay owns x=384..458/y=18..56. -->
    <Rectangle x="183" y="15" w="282" h="274" cornerRadius="29" fillColor="#ff292926"/>
    <Rectangle x="184" y="16" w="280" h="272" cornerRadius="28" fillColor="#ff171715"/>

    <!-- OuterView mark: a neutral ring, intentionally not an OpenAI logo. -->
    <Circle x="204" y="41" r="8" fillColor="#fff4f4ef"/>
    <Circle x="204" y="41" r="4" fillColor="#ff171715"/>
    <Circle x="209" y="36" r="2" fillColor="#ff10a37f"/>
    <Text x="218" y="29" size="15" color="#fff4f4ef" text="OuterView" fontFamily="mipro-demibold"/>
    <Text x="218" y="48" size="9" color="#ff7c7c76" text="CODEX USAGE" fontFamily="mipro-medium"/>

    <!-- Both windows. -->
    <Group visibility="#quotaState==3">
      <Text x="204" y="73" size="12" color="#ffb0b0a8" text="5-hour" fontFamily="mipro-medium"/>
      <Text x="444" y="62" size="32" color="#fff4f4ef" align="right" textExp="@fiveLabel" fontFamily="mipro-demibold"/>
      <Rectangle x="204" y="105" w="240" h="6" cornerRadius="3" fillColor="#ff30302d"/>
      <Rectangle x="204" y="105" w="(240*#fiveSafe/100)" h="6" cornerRadius="3" fillColor="#fiveColor"/>
      <Text x="204" y="119" size="10" color="#ff7c7c76" textExp="'Resets '+@five_hour_reset" fontFamily="mipro-medium"/>

      <Rectangle x="204" y="144" w="240" h="1" fillColor="#ff292926"/>

      <Text x="204" y="164" size="12" color="#ffb0b0a8" text="Weekly" fontFamily="mipro-medium"/>
      <Text x="444" y="153" size="32" color="#fff4f4ef" align="right" textExp="@weekLabel" fontFamily="mipro-demibold"/>
      <Rectangle x="204" y="196" w="240" h="6" cornerRadius="3" fillColor="#ff30302d"/>
      <Rectangle x="204" y="196" w="(240*#weekSafe/100)" h="6" cornerRadius="3" fillColor="#weekColor"/>
      <Text x="204" y="210" size="10" color="#ff7c7c76" textExp="'Resets '+@weekly_reset" fontFamily="mipro-medium"/>
    </Group>

    <!-- One window: Weekly-only or 5-hour-only. -->
    <Group visibility="(#quotaState!=0) ** (#quotaState!=3)">
      <Text x="204" y="80" size="12" color="#ffb0b0a8" textExp="@singleTitle" fontFamily="mipro-medium"/>
      <Text x="204" y="100" size="60" color="#fff4f4ef" textExp="@singleLabel" fontFamily="mipro-demibold"/>
      <Rectangle x="204" y="176" w="240" h="8" cornerRadius="4" fillColor="#ff30302d"/>
      <Rectangle x="204" y="176" w="(240*#singleSafe/100)" h="8" cornerRadius="4" fillColor="#singleColor"/>
      <Text x="204" y="195" size="11" color="#ff7c7c76" textExp="'Resets '+@singleReset" fontFamily="mipro-medium"/>
    </Group>

    <!-- Empty and disconnected states. -->
    <Group visibility="#quotaState==0">
      <Circle x="216" y="109" r="18" fillColor="#ff30302d"/>
      <Circle x="216" y="109" r="11" fillColor="#ff171715"/>
      <Circle x="227" y="98" r="3" fillColor="#ffb0b0a8"/>
      <Text x="204" y="143" size="21" color="#fff4f4ef" textExp="@emptyTitle" fontFamily="mipro-demibold"/>
      <Text x="204" y="174" size="11" color="#ff7c7c76" textExp="@emptyDetail" fontFamily="mipro-medium"/>
    </Group>

    <!-- The footer is also the manual refresh affordance. -->
    <Circle x="207" y="262" r="3" fillColor="#statusColor"/>
    <Text x="216" y="254" size="10" color="#ff7c7c76" textExp="@footerLabel" fontFamily="mipro-medium"/>
    <Text x="444" y="254" size="9" color="#ff7c7c76" align="right" text="TAP TO REFRESH" fontFamily="mipro-medium"/>
  </Group>

  <VariableBinders>
    <ContentProviderBinder name="CodexQuota" uri="content://org.orynnx.codexquota/quota" columns="five_hour_remaining,five_hour_reset,weekly_remaining,weekly_reset,plan,status,updated_at">
      <Variable name="five_hour_remaining" type="int" column="five_hour_remaining"/>
      <Variable name="five_hour_reset" type="string" column="five_hour_reset"/>
      <Variable name="weekly_remaining" type="int" column="weekly_remaining"/>
      <Variable name="weekly_reset" type="string" column="weekly_reset"/>
      <Variable name="plan" type="string" column="plan"/>
      <Variable name="status" type="string" column="status"/>
      <Variable name="updated_at" type="string" column="updated_at"/>
    </ContentProviderBinder>
  </VariableBinders>

  <!-- Active refresh: first render, every resume, and once per minute. -->
  <ExternalCommands>
    <Trigger action="init,resume"><BinderCommand name="CodexQuota" command="refresh"/></Trigger>
  </ExternalCommands>
  <Var expression="#time_sys" threshold="60000"><Trigger><BinderCommand name="CodexQuota" command="refresh"/></Trigger></Var>

  <!--
    Root-level transparent hit target follows the proven dino_game touch pattern.
    It uses the host's real view bounds, so scale/offset math cannot make the
    visible TAP TO REFRESH footer miss the touch region.
  -->
  <Group x="0" y="0" w="#view_width" h="#view_height" alpha="0"
         touchable="true" interceptTouch="true">
    <Triggers>
      <Trigger action="up"><BinderCommand name="CodexQuota" command="refresh"/></Trigger>
    </Triggers>
  </Group>
</Widget>
